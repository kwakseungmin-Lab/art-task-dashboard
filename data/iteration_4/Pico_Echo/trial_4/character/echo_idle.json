  "task_id": "pico_echo.character.echo_idle",
  "asset_name": "echo_idle",
  "category": "character",
  "subcategory": "echo_state",
  "description": "Create Echo idle animation as a horizontal sprite strip. Echo sprite frame size is 40x40px. Primary body color #FFA300, cheek patch #FF004D, crest #FFEC27, beak+feet #AB5236, eyes #1D2B53. Eyes are 2x2px blocks. No additional colors beyond the pico8_16 palette. No anti-aliasing; 1px steps only. Animation: 4 frames, 2 FPS, loop infinite. Spritesheet dimensions 160x40px (4 frames x 40px wide). Frame content rules: F1: eyes open (two 2x2 #1D2B53 blocks). F2: eyes open; move crest up by 1px compared to F1 (crest top pixels y-1). F3: eyes closed (replace each eye block with a 2x1 #1D2B53 line at the eye's bottom row). F4: eyes open; identical to F1. Echo stands centered: body bounding box occupies x=8..31, y=6..33 within each 40x40 frame. Feet (2px wide each, #AB5236) touch perch line when placed at screen y=60 over perch at y=80; therefore feet bottom row inside frame must be at local y=33.",
  "deliverables": [
    {
      "type": "source",
      "path": "art/pico_echo/source/character/echo_idle.aseprite",
      "format": "aseprite",
      "notes": "Aseprite source file with layers and frames (no palette outside pico8_16)."
    },
    {
      "type": "export",
      "path": "art/pico_echo/export/character/echo_idle.png",
      "format": "png",
      "notes": "PNG export (indexed color, 16-color palette, nearest-neighbor scaling)."
    }
  ],
  "specs": {
    "dimensions": "160x40",
    "frame_size": "40x40",
    "animation": {
      "frames": 4,
      "fps": 2,
      "loop": "infinite",
      "spritesheet_layout": "horizontal_strip"
    },
    "export_alignment": {
      "anchor": "center",
      "feet_bottom_local_y": 33
    }
  },
  "context": {
