  "task_id": "pico_echo.character.echo_eating",
  "asset_name": "echo_eating",
  "category": "character",
  "subcategory": "echo_state",
  "description": "Create Echo eating animation as a horizontal sprite strip. Echo sprite frame size is 40x40px. Primary body color #FFA300, cheek patch #FF004D, crest #FFEC27, beak+feet #AB5236, eyes #1D2B53. Eyes are 2x2px blocks. No additional colors beyond the pico8_16 palette. No anti-aliasing; 1px steps only. Animation: 6 frames, 4 FPS, play once (non-loop) then return to idle. Spritesheet dimensions 240x40px. Head motion: frames 1-3 move head/beak down toward food bowl by +2px in y each frame (cumulative +6px by F3). Frame 4: beak open (beak triangle split into two 1px-separated halves). Frame 5: include a single 3x3 seed (#FFA300) touching beak tip at local position x=26,y=26. Frame 6: head returns up by -6px to match idle head height. Body stays centered (bounding box x=8..31,y=6..33) across all frames; only head/crest/beak region moves.",
  "deliverables": [
    {
      "type": "source",
      "path": "art/pico_echo/source/character/echo_eating.aseprite",
      "format": "aseprite",
      "notes": "Aseprite source file with layers and frames (no palette outside pico8_16)."
    },
    {
      "type": "export",
      "path": "art/pico_echo/export/character/echo_eating.png",
      "format": "png",
      "notes": "PNG export (indexed color, 16-color palette, nearest-neighbor scaling)."
    }
  ],
  "specs": {
