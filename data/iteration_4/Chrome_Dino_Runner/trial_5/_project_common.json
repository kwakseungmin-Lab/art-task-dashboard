      }
    },
    "palette": {
      "background": "#F7F7F7",
      "primary": "#535353",
      "highlight": "#FF0000",
      "allowed_colors": [
        "#F7F7F7",
        "#535353",
        "#FF0000",
        "#FFFFFF"
      ],
      "rules": [
        "All gameplay sprites (player, obstacles, ground, clouds) use only #535353 for non-transparent pixels.",
        "Background sky uses only #F7F7F7 (no transparency).",
        "UI text uses only #535353. White (#FFFFFF) is allowed only for runtime flash effects or overlays."
      ]
    },
    "sprite_standards": {
      "outline": {
        "enabled": true,
        "thickness_px": 2,
        "color": "#535353",
        "rule": "Sprite silhouettes must have a minimum 2px-thick edge where applicable; no 1px hairline edges."
      },
      "transparency": {
        "background": "transparent",
        "alpha_requirement": "All non-background sprites must have fully transparent background (alpha=0) outside the silhouette."
      },
      "scale_support": {
        "base_scale": "1x",
        "secondary_scale": "2x",
        "scaling_method": "nearest_neighbor",
        "note": "Export 1x originals; 2x exports must be integer-scaled using nearest-neighbor (no filtering)."
      }
    },
    "export": {
      "formats": [
        "png"
      ],
      "color_space": "sRGB",
      "png": {
        "bit_depth": 8,
        "interlaced": false
      },
      "naming": {
        "frame_indexing": "1-based in filenames where specified by GDD (e.g., dino_run_1.png, dino_run_2.png)",
        "scale_suffix": "@2x"
      }
    },
    "priorities": {
      "scheme": "P0-P3",
      "definitions": {
        "P0": "Required for a playable MVP (core gameplay and essential UI).",
        "P1": "Feature-complete look but not strictly blocking MVP.",
        "P2": "Optional polish.",
        "P3": "Nice-to-have polish."
      }
    },
